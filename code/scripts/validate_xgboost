from pathlib import Path
import argparse
from datetime import datetime

import joblib
import pandas as pd
from sklearn.metrics import mean_absolute_error, mean_squared_error, r2_score

SCRIPT_PATH = Path(__file__).resolve()
PROJECT_ROOT = SCRIPT_PATH.parent.parent
SOURCE_TRAIN_DIR = PROJECT_ROOT / "bin" / "train"
SOURCE_TEST_DIR = PROJECT_ROOT / "bin" / "test"
XGB_BIN_DIR = PROJECT_ROOT / "bin" / "XGBoost"
XGB_TRAIN_DIR = XGB_BIN_DIR / "train"
XGB_TEST_DIR = XGB_BIN_DIR / "test"

MODEL_PATH = XGB_TRAIN_DIR / "delta_y_model.pkl"

TARGET_MAP = [
    ("Simulation_Voc", "JV_default_Voc", "delta_Voc"),
    ("Simulation_Jsc", "JV_default_Jsc", "delta_Jsc"),
    ("Simulation_PCE", "JV_default_PCE", "delta_PCE"),
    ("Simulation_FF", "JV_default_FF", "delta_FF"),
]


def parse_args():
    parser = argparse.ArgumentParser(
        description="使用 XGBoost 模型评估 train/test 数据集，并可对比过拟合迹象。"
    )
    parser.add_argument(
        "--dataset",
        choices=["train", "test", "both"],
        default="test",
        help="选择要评估的数据集；both 会同时评估 train 与 test 并输出对比表。",
    )
    return parser.parse_args()


def resolve_dataset_paths(dataset):
    if dataset == "train":
        source_data_dir = SOURCE_TRAIN_DIR
        output_data_dir = XGB_TRAIN_DIR
    else:
        source_data_dir = SOURCE_TEST_DIR
        output_data_dir = XGB_TEST_DIR

    return {
        "x_path": source_data_dir / f"{dataset}_x.csv",
        "y_path": source_data_dir / f"{dataset}_y.csv",
        "y_hat_path": source_data_dir / f"{dataset}_y_hat.csv",
        "prediction_output": output_data_dir / f"{dataset}_delta_y_predictions.csv",
        "metric_output": output_data_dir / f"{dataset}_delta_y_metrics.csv",
    }


def load_dataset(dataset_paths, dataset_name):
    x_path = dataset_paths["x_path"]
    y_path = dataset_paths["y_path"]
    y_hat_path = dataset_paths["y_hat_path"]

    for file_path in (x_path, y_path, y_hat_path):
        if not file_path.exists():
            raise FileNotFoundError(f"缺少 {dataset_name} 文件: {file_path}")

    data_x = pd.read_csv(x_path).sort_values("Ref_ID").reset_index(drop=True)
    data_y = pd.read_csv(y_path).sort_values("Ref_ID").reset_index(drop=True)
    data_y_hat = pd.read_csv(y_hat_path).sort_values("Ref_ID").reset_index(drop=True)

    if not (
        data_x["Ref_ID"].equals(data_y["Ref_ID"])
        and data_y["Ref_ID"].equals(data_y_hat["Ref_ID"])
    ):
        raise ValueError(
            f"{dataset_name}_x/{dataset_name}_y/{dataset_name}_y_hat 的 Ref_ID 未完全对齐。"
        )

    return data_x, data_y, data_y_hat


def build_true_delta(data_y, data_y_hat):
    delta_true = pd.DataFrame(index=data_y.index)
    for y_col, y_hat_col, delta_col in TARGET_MAP:
        if y_col not in data_y.columns:
            raise KeyError(f"{y_col} 不存在于 y 文件中")
        if y_hat_col not in data_y_hat.columns:
            raise KeyError(f"{y_hat_col} 不存在于 y_hat 文件中")
        y_num = pd.to_numeric(data_y[y_col], errors="coerce")
        y_hat_num = pd.to_numeric(data_y_hat[y_hat_col], errors="coerce")
        delta_true[delta_col] = y_num - y_hat_num
    return delta_true


def evaluate_predictions(delta_true, delta_pred, dataset_name):
    rows = []
    print(f"\n{dataset_name} 集 delta_y 评估结果 (XGBoost):")
    for col in delta_true.columns:
        valid_mask = ~(delta_true[col].isna() | delta_pred[col].isna())
        y_true_col = delta_true.loc[valid_mask, col]
        y_pred_col = delta_pred.loc[valid_mask, col]

        mae = mean_absolute_error(y_true_col, y_pred_col)
        mse = mean_squared_error(y_true_col, y_pred_col)
        rmse = mse**0.5
        r2 = r2_score(y_true_col, y_pred_col)

        rows.append(
            {
                "target": col,
                "sample_count": int(valid_mask.sum()),
                "MAE": mae,
                "MSE": mse,
                "RMSE": rmse,
                "R2": r2,
            }
        )
        print(
            f"{col}: N={int(valid_mask.sum())}, "
            f"MAE={mae:.6f}, MSE={mse:.6f}, RMSE={rmse:.6f}, R2={r2:.6f}"
        )
    return pd.DataFrame(rows)


def safe_save_csv(df, output_path):
    try:
        output_path.parent.mkdir(parents=True, exist_ok=True)
        df.to_csv(output_path, index=False, encoding="utf-8-sig")
        return output_path
    except PermissionError:
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        fallback_path = output_path.with_name(
            f"{output_path.stem}_{timestamp}{output_path.suffix}"
        )
        df.to_csv(fallback_path, index=False, encoding="utf-8-sig")
        print(
            f"⚠️ 无法写入 {output_path}（可能正被占用），"
            f"已改为保存到: {fallback_path}"
        )
        return fallback_path


def run_single_dataset(model, dataset):
    dataset_paths = resolve_dataset_paths(dataset)
    print(f"\n正在评估数据集 (XGBoost): {dataset}")
    data_x, data_y, data_y_hat = load_dataset(dataset_paths, dataset)
    x_features = data_x.drop(columns=["Ref_ID"]).copy()
    delta_true = build_true_delta(data_y, data_y_hat)

    delta_pred_array = model.predict(x_features)
    delta_pred = pd.DataFrame(
        delta_pred_array, columns=delta_true.columns, index=delta_true.index
    )

    metrics_df = evaluate_predictions(delta_true, delta_pred, dataset)

    result_df = pd.DataFrame({"Ref_ID": data_x["Ref_ID"]})
    for col in delta_true.columns:
        result_df[f"{col}_true"] = delta_true[col]
        result_df[f"{col}_pred"] = delta_pred[col]
        result_df[f"{col}_error"] = delta_pred[col] - delta_true[col]

    prediction_output = dataset_paths["prediction_output"]
    metric_output = dataset_paths["metric_output"]
    saved_prediction_path = safe_save_csv(result_df, prediction_output)
    saved_metric_path = safe_save_csv(metrics_df, metric_output)

    print(f"已保存逐样本对比结果: {saved_prediction_path}")
    print(f"已保存指标汇总结果: {saved_metric_path}")

    return metrics_df


def build_overfit_comparison(metrics_train, metrics_test):
    train_df = metrics_train.rename(
        columns={
            "sample_count": "train_sample_count",
            "MAE": "train_MAE",
            "MSE": "train_MSE",
            "RMSE": "train_RMSE",
            "R2": "train_R2",
        }
    )
    test_df = metrics_test.rename(
        columns={
            "sample_count": "test_sample_count",
            "MAE": "test_MAE",
            "MSE": "test_MSE",
            "RMSE": "test_RMSE",
            "R2": "test_R2",
        }
    )
    merged = pd.merge(train_df, test_df, on="target", how="inner")
    merged["gap_MAE(test-train)"] = merged["test_MAE"] - merged["train_MAE"]
    merged["gap_RMSE(test-train)"] = merged["test_RMSE"] - merged["train_RMSE"]
    merged["gap_R2(train-test)"] = merged["train_R2"] - merged["test_R2"]
    return merged


def main():
    args = parse_args()
    dataset = args.dataset

    if not MODEL_PATH.exists():
        raise FileNotFoundError(
            f"找不到 XGBoost 模型: {MODEL_PATH}。请先运行 scripts/train_xgboost。"
        )

    print(f"加载 XGBoost 模型: {MODEL_PATH}")
    model = joblib.load(MODEL_PATH)

    if dataset in {"train", "test"}:
        run_single_dataset(model, dataset)
        return

    metrics_train = run_single_dataset(model, "train")
    metrics_test = run_single_dataset(model, "test")
    compare_df = build_overfit_comparison(metrics_train, metrics_test)
    compare_output = XGB_BIN_DIR / "overfit_comparison.csv"
    saved_compare_path = safe_save_csv(compare_df, compare_output)

    print("\nXGBoost train/test 指标对比:")
    for _, row in compare_df.iterrows():
        print(
            f"{row['target']}: "
            f"train_R2={row['train_R2']:.6f}, test_R2={row['test_R2']:.6f}, "
            f"R2差(train-test)={row['gap_R2(train-test)']:.6f}"
        )
    print(f"\n已保存过拟合对比表: {saved_compare_path}")


if __name__ == "__main__":
    main()
