from pathlib import Path

import joblib
import pandas as pd
from sklearn.compose import ColumnTransformer
from sklearn.impute import SimpleImputer
from sklearn.metrics import mean_squared_error, r2_score
from sklearn.model_selection import train_test_split
from sklearn.multioutput import MultiOutputRegressor
from sklearn.pipeline import Pipeline
from sklearn.preprocessing import OneHotEncoder, StandardScaler

try:
    from xgboost import XGBRegressor
except ModuleNotFoundError as exc:
    raise ModuleNotFoundError(
        "未安装 xgboost，请先运行: .\\.venv\\Scripts\\python.exe -m pip install xgboost"
    ) from exc

SCRIPT_PATH = Path(__file__).resolve()
PROJECT_ROOT = SCRIPT_PATH.parent.parent
SOURCE_TRAIN_DIR = PROJECT_ROOT / "bin" / "train"
XGB_TRAIN_DIR = PROJECT_ROOT / "bin" / "XGBoost" / "train"

TARGET_MAP = [
    ("Simulation_Voc", "JV_default_Voc", "delta_Voc"),
    ("Simulation_Jsc", "JV_default_Jsc", "delta_Jsc"),
    ("Simulation_PCE", "JV_default_PCE", "delta_PCE"),
    ("Simulation_FF", "JV_default_FF", "delta_FF"),
]


def load_train_dataset():
    x_path = SOURCE_TRAIN_DIR / "train_x.csv"
    y_path = SOURCE_TRAIN_DIR / "train_y.csv"
    y_hat_path = SOURCE_TRAIN_DIR / "train_y_hat.csv"

    for file_path in (x_path, y_path, y_hat_path):
        if not file_path.exists():
            raise FileNotFoundError(f"缺少训练文件: {file_path}")

    df_x = pd.read_csv(x_path).sort_values("Ref_ID").reset_index(drop=True)
    df_y = pd.read_csv(y_path).sort_values("Ref_ID").reset_index(drop=True)
    df_y_hat = pd.read_csv(y_hat_path).sort_values("Ref_ID").reset_index(drop=True)

    if not (
        df_x["Ref_ID"].equals(df_y["Ref_ID"])
        and df_y["Ref_ID"].equals(df_y_hat["Ref_ID"])
    ):
        raise ValueError("train_x/train_y/train_y_hat 的 Ref_ID 未完全对齐。")

    return df_x, df_y, df_y_hat


def build_xy(df_x, df_y, df_y_hat):
    x = df_x.drop(columns=["Ref_ID"]).copy()
    delta_y = pd.DataFrame(index=df_y.index)

    for y_col, y_hat_col, delta_col in TARGET_MAP:
        if y_col not in df_y.columns:
            raise KeyError(f"train_y.csv 缺少列: {y_col}")
        if y_hat_col not in df_y_hat.columns:
            raise KeyError(f"train_y_hat.csv 缺少列: {y_hat_col}")
        y_numeric = pd.to_numeric(df_y[y_col], errors="coerce")
        y_hat_numeric = pd.to_numeric(df_y_hat[y_hat_col], errors="coerce")
        delta_y[delta_col] = y_numeric - y_hat_numeric

    valid_mask = ~delta_y.isna().any(axis=1)
    dropped_rows = int((~valid_mask).sum())
    if dropped_rows > 0:
        print(f"检测到 {dropped_rows} 行目标值缺失，已从训练集中移除。")

    x = x.loc[valid_mask].reset_index(drop=True)
    delta_y = delta_y.loc[valid_mask].reset_index(drop=True)

    if len(delta_y) < 20:
        raise ValueError("可用于训练的有效样本过少（<20），请检查 train_y/train_y_hat 的缺失值。")

    return x, delta_y


def build_model(x_sample):
    categorical_cols = x_sample.select_dtypes(
        include=["object", "category", "string"]
    ).columns
    numeric_cols = x_sample.select_dtypes(include=["number"]).columns

    preprocessor = ColumnTransformer(
        transformers=[
            (
                "num",
                Pipeline(
                    steps=[
                        ("imputer", SimpleImputer(strategy="median")),
                        ("scaler", StandardScaler()),
                    ]
                ),
                list(numeric_cols),
            ),
            (
                "cat",
                Pipeline(
                    steps=[
                        ("imputer", SimpleImputer(strategy="most_frequent")),
                        ("encoder", OneHotEncoder(handle_unknown="ignore")),
                    ]
                ),
                list(categorical_cols),
            ),
        ]
    )

    base_regressor = XGBRegressor(
        n_estimators=500,
        learning_rate=0.05,
        max_depth=6,
        min_child_weight=3,
        subsample=0.9,
        colsample_bytree=0.9,
        objective="reg:squarederror",
        random_state=42,
        n_jobs=-1,
    )

    return Pipeline(
        steps=[
            ("preprocessor", preprocessor),
            ("regressor", MultiOutputRegressor(base_regressor)),
        ]
    )


def main():
    print(f"XGBoost 训练数据目录(输入): {SOURCE_TRAIN_DIR}")
    print(f"XGBoost 输出目录: {XGB_TRAIN_DIR}")

    df_x, df_y, df_y_hat = load_train_dataset()
    x, delta_y = build_xy(df_x, df_y, df_y_hat)

    x_train, x_valid, y_train, y_valid = train_test_split(
        x, delta_y, test_size=0.2, random_state=42
    )

    model = build_model(x_train)
    model.fit(x_train, y_train)

    y_pred = model.predict(x_valid)
    y_pred_df = pd.DataFrame(y_pred, columns=y_valid.columns, index=y_valid.index)

    print("\nXGBoost 验证集指标 (delta_y):")
    for col in y_valid.columns:
        mse = mean_squared_error(y_valid[col], y_pred_df[col])
        r2 = r2_score(y_valid[col], y_pred_df[col])
        print(f"{col}: MSE={mse:.6f}, R2={r2:.6f}")

    XGB_TRAIN_DIR.mkdir(parents=True, exist_ok=True)
    model_path = XGB_TRAIN_DIR / "delta_y_model.pkl"
    joblib.dump(model, model_path)
    print(f"\nXGBoost 模型已保存: {model_path}")


if __name__ == "__main__":
    main()
