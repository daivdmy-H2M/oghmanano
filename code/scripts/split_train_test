from pathlib import Path

import pandas as pd
from sklearn.model_selection import train_test_split

SCRIPT_PATH = Path(__file__).resolve()
PROJECT_ROOT = SCRIPT_PATH.parent.parent
ANALYSES_DIR = PROJECT_ROOT / "bin" / "analyses1"
TRAIN_DIR = PROJECT_ROOT / "bin" / "train"
TEST_DIR = PROJECT_ROOT / "bin" / "test"

RANDOM_STATE = 42
TEST_SIZE = 0.25

# 用于自动识别 delta_Jsc 对比图中异常点（例如实际值约 -4.2 的点）
OUTLIER_TARGET_COL = "delta_Jsc_true"
OUTLIER_EXPECTED_VALUE = -4.2
OUTLIER_TOLERANCE = 0.25
MANUAL_EXCLUDE_FILE = PROJECT_ROOT / "bin" / "excluded_ref_ids.txt"
FF_OUTLIER_THRESHOLD = -1.0


def load_aligned_inputs():
    x_path = ANALYSES_DIR / "analyses_x.csv"
    y_path = ANALYSES_DIR / "analyses_y.csv"
    y_hat_path = ANALYSES_DIR / "analyses_y_hat.csv"

    for file_path in (x_path, y_path, y_hat_path):
        if not file_path.exists():
            raise FileNotFoundError(f"缺少输入文件: {file_path}")

    df_x = pd.read_csv(x_path).sort_values("Ref_ID").reset_index(drop=True)
    df_y = pd.read_csv(y_path).sort_values("Ref_ID").reset_index(drop=True)
    df_y_hat = pd.read_csv(y_hat_path).sort_values("Ref_ID").reset_index(drop=True)

    # 关键要求：剔除 analyses_y.csv 中的 JV_default_Voc，避免污染
    if "JV_default_Voc" in df_y.columns:
        df_y = df_y.drop(columns=["JV_default_Voc"])
        print("已从 analyses_y 中剔除列: JV_default_Voc")

    if not (
        df_x["Ref_ID"].equals(df_y["Ref_ID"])
        and df_y["Ref_ID"].equals(df_y_hat["Ref_ID"])
    ):
        raise ValueError("analyses_x / analyses_y / analyses_y_hat 的 Ref_ID 未完全对齐。")

    return df_x, df_y, df_y_hat


def collect_ref_ids_to_exclude():
    excluded_ids = set()

    # 1) 手工指定排除列表（每行一个 Ref_ID，支持 # 注释）
    if MANUAL_EXCLUDE_FILE.exists():
        for line in MANUAL_EXCLUDE_FILE.read_text(encoding="utf-8-sig").splitlines():
            line = line.strip()
            if not line or line.startswith("#"):
                continue
            excluded_ids.add(line)

    # 2) 自动识别：从 train/test 预测结果里寻找 delta_Jsc_true ≈ -4.2 的样本
    for split in ("train", "test"):
        pred_path = PROJECT_ROOT / "bin" / split / f"{split}_delta_y_predictions.csv"
        if not pred_path.exists():
            continue

        pred_df = pd.read_csv(pred_path)
        if not {"Ref_ID", OUTLIER_TARGET_COL}.issubset(pred_df.columns):
            continue

        pred_df[OUTLIER_TARGET_COL] = pd.to_numeric(
            pred_df[OUTLIER_TARGET_COL], errors="coerce"
        )
        hit_mask = (
            pred_df[OUTLIER_TARGET_COL] - OUTLIER_EXPECTED_VALUE
        ).abs() <= OUTLIER_TOLERANCE
        hit_ids = pred_df.loc[hit_mask, "Ref_ID"].astype(str).tolist()
        excluded_ids.update(hit_ids)

    return excluded_ids


def collect_ff_outlier_ref_ids(df_x, df_y, df_y_hat):
    """全局清洗 FF 明显异常样本：Simulation_FF - JV_default_FF < -1。"""
    missing_cols = []
    if "Simulation_FF" not in df_y.columns:
        missing_cols.append("Simulation_FF (analyses_y)")
    if "JV_default_FF" not in df_y_hat.columns:
        missing_cols.append("JV_default_FF (analyses_y_hat)")
    if missing_cols:
        print(
            "未执行 FF 全局清洗：缺少列 "
            f"{missing_cols}。"
        )
        return set()

    simulation_ff = pd.to_numeric(df_y["Simulation_FF"], errors="coerce")
    jv_default_ff = pd.to_numeric(df_y_hat["JV_default_FF"], errors="coerce")
    ff_delta = simulation_ff - jv_default_ff

    outlier_mask = ff_delta < FF_OUTLIER_THRESHOLD
    outlier_ids = set(df_x.loc[outlier_mask, "Ref_ID"].astype(str).tolist())

    print(
        "FF 全局清洗规则: "
        f"Simulation_FF - JV_default_FF < {FF_OUTLIER_THRESHOLD}，"
        f"识别到 {len(outlier_ids)} 条样本。"
    )
    return outlier_ids


def split_and_save(df_x, df_y, df_y_hat, excluded_ids):
    if excluded_ids:
        print(f"检测到需剔除的 Ref_ID: {sorted(excluded_ids)}")
        keep_mask = ~df_x["Ref_ID"].astype(str).isin(excluded_ids)
        dropped_count = int((~keep_mask).sum())
        df_x = df_x.loc[keep_mask].reset_index(drop=True)
        df_y = df_y.loc[keep_mask].reset_index(drop=True)
        df_y_hat = df_y_hat.loc[keep_mask].reset_index(drop=True)
        print(f"已剔除异常样本 {dropped_count} 条，进入重新切分流程。")
    else:
        print(
            "未在现有预测结果中检出 delta_Jsc_true≈-4.2 的 Ref_ID；"
            "如需强制剔除，请在 bin/excluded_ref_ids.txt 中手工填写。"
        )

    ref_ids = df_x["Ref_ID"]
    train_ids, test_ids = train_test_split(
        ref_ids, test_size=TEST_SIZE, random_state=RANDOM_STATE, shuffle=True
    )
    train_id_set = set(train_ids.tolist())

    train_mask = df_x["Ref_ID"].isin(train_id_set)
    test_mask = ~train_mask

    train_x = df_x.loc[train_mask].sort_values("Ref_ID").reset_index(drop=True)
    train_y = df_y.loc[train_mask].sort_values("Ref_ID").reset_index(drop=True)
    train_y_hat = df_y_hat.loc[train_mask].sort_values("Ref_ID").reset_index(drop=True)

    test_x = df_x.loc[test_mask].sort_values("Ref_ID").reset_index(drop=True)
    test_y = df_y.loc[test_mask].sort_values("Ref_ID").reset_index(drop=True)
    test_y_hat = df_y_hat.loc[test_mask].sort_values("Ref_ID").reset_index(drop=True)

    TRAIN_DIR.mkdir(parents=True, exist_ok=True)
    TEST_DIR.mkdir(parents=True, exist_ok=True)

    train_x.to_csv(TRAIN_DIR / "train_x.csv", index=False, encoding="utf-8-sig")
    train_y.to_csv(TRAIN_DIR / "train_y.csv", index=False, encoding="utf-8-sig")
    train_y_hat.to_csv(TRAIN_DIR / "train_y_hat.csv", index=False, encoding="utf-8-sig")

    test_x.to_csv(TEST_DIR / "test_x.csv", index=False, encoding="utf-8-sig")
    test_y.to_csv(TEST_DIR / "test_y.csv", index=False, encoding="utf-8-sig")
    test_y_hat.to_csv(TEST_DIR / "test_y_hat.csv", index=False, encoding="utf-8-sig")

    print("数据集切分完成（随机 3:1）:")
    print(f"  train: {len(train_x)} 条")
    print(f"  test : {len(test_x)} 条")
    print(f"  输出目录: {TRAIN_DIR} 和 {TEST_DIR}")


def main():
    df_x, df_y, df_y_hat = load_aligned_inputs()
    excluded_ids = collect_ref_ids_to_exclude()
    ff_outlier_ids = collect_ff_outlier_ref_ids(df_x, df_y, df_y_hat)
    excluded_ids = excluded_ids.union(ff_outlier_ids)
    split_and_save(df_x, df_y, df_y_hat, excluded_ids)


if __name__ == "__main__":
    main()
