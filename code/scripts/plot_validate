from pathlib import Path
import argparse
import importlib.util
import sys

import numpy as np
import pandas as pd

SCRIPT_PATH = Path(__file__).resolve()
PROJECT_ROOT = SCRIPT_PATH.parent.parent
BIN_DIR = PROJECT_ROOT / "bin"


def parse_args():
    parser = argparse.ArgumentParser(
        description="对 train/test 的 delta_y 预测结果绘制对比与回归图。"
    )
    parser.add_argument(
        "--dataset",
        choices=["train", "test"],
        default="test",
        help="选择要绘图的数据集，默认 test。",
    )
    return parser.parse_args()


def resolve_paths(dataset):
    data_dir = BIN_DIR / dataset
    return {
        "pred_path": data_dir / f"{dataset}_delta_y_predictions.csv",
        "figure_dir": data_dir / "figures",
    }


def discover_targets(columns):
    """从 *_true 列自动识别目标名。"""
    targets = []
    for col in columns:
        if col.endswith("_true"):
            targets.append(col[: -len("_true")])
    return targets


def plot_for_target(df, target, output_dir, plt):
    true_col = f"{target}_true"
    pred_col = f"{target}_pred"
    err_col = f"{target}_error"

    if not {true_col, pred_col, err_col}.issubset(df.columns):
        raise KeyError(f"缺少绘图所需列: {true_col}, {pred_col}, {err_col}")

    sub_df = df[[true_col, pred_col, err_col]].dropna()
    if sub_df.empty:
        print(f"⚠️ {target}: 可用数据为空，跳过绘图。")
        return

    plt.figure(figsize=(12, 5), dpi=120)

    # 左图：真实 vs 预测散点图
    ax1 = plt.subplot(1, 2, 1)
    ax1.scatter(
        sub_df[true_col],
        sub_df[pred_col],
        c="#1f77b4",
        s=25,
        alpha=0.75,
        edgecolors="none",
    )
    min_val = min(sub_df[true_col].min(), sub_df[pred_col].min())
    max_val = max(sub_df[true_col].max(), sub_df[pred_col].max())
    ax1.plot([min_val, max_val], [min_val, max_val], color="black", linewidth=1, label="y=x")
    if len(sub_df) >= 2:
        slope, intercept = np.polyfit(sub_df[true_col], sub_df[pred_col], deg=1)
        reg_x = np.array([min_val, max_val])
        reg_y = slope * reg_x + intercept
        ax1.plot(reg_x, reg_y, color="#d62728", linewidth=1.2, label="Regression")
        ax1.text(
            0.02,
            0.98,
            f"y={slope:.3f}x+{intercept:.3f}",
            transform=ax1.transAxes,
            ha="left",
            va="top",
            fontsize=9,
        )
    ax1.set_title(f"{target}: True vs Pred")
    ax1.set_xlabel("True delta_y")
    ax1.set_ylabel("Pred delta_y")
    ax1.grid(alpha=0.25)
    ax1.legend(loc="lower right", fontsize=8)

    # 右图：误差分布图
    ax2 = plt.subplot(1, 2, 2)
    ax2.hist(sub_df[err_col], bins=30, color="#ff7f0e", alpha=0.8, edgecolor="white")
    ax2.axvline(0, color="black", linewidth=1)
    ax2.set_title(f"{target}: Error Distribution")
    ax2.set_xlabel("Prediction Error (pred - true)")
    ax2.set_ylabel("Count")
    ax2.grid(alpha=0.25)

    plt.tight_layout()
    output_path = output_dir / f"{target}_analysis.png"
    plt.savefig(output_path, bbox_inches="tight")
    plt.close()
    print(f"✅ 已保存图像: {output_path}")


def main():
    args = parse_args()
    dataset = args.dataset
    paths = resolve_paths(dataset)
    pred_path = paths["pred_path"]
    figure_dir = paths["figure_dir"]

    if importlib.util.find_spec("matplotlib") is None:
        print("❌ 未检测到 matplotlib，无法绘图。")
        print("请先安装依赖后再运行：")
        print(r"  .\.venv\Scripts\python.exe -m pip install -r .\requirements-train.txt")
        sys.exit(1)

    import matplotlib.pyplot as plt

    if not pred_path.exists():
        raise FileNotFoundError(
            f"找不到预测结果文件: {pred_path}。请先运行 scripts/validate。"
        )

    figure_dir.mkdir(parents=True, exist_ok=True)
    df = pd.read_csv(pred_path)
    targets = discover_targets(df.columns)

    if not targets:
        raise ValueError("未在预测文件中发现 *_true 列，无法识别目标字段。")

    print(f"将为以下目标绘图: {targets}")
    for target in targets:
        plot_for_target(df, target, figure_dir, plt)

    print("\n全部分析图已生成完成。")


if __name__ == "__main__":
    main()
